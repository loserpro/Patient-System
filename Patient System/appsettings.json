{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        // 替换为你的 MySQL 地址/账号/密码
        "MySqlConnection": "server=localhost;port=数据库端口;database=你的库;user=数据库用户名;password=数据库密码;charset=utf8mb4;"
    },
    "Jwt": {
        "Key": "your_secret_key_1234567890abcdefghijklmn", // jwt密钥
        "Issuer": "AspNetCore_EFCore_MySQL",
        "Audience": "UserClient"
    }


}
